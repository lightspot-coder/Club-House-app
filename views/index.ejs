<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%=title%></title>
  </head>
  <body>
    <h2>Welcome to the clubhouse app</h2>
    <ul>
        <% messages.map(message => { %>
            <li>
                <h3><%=message.title%> written by <%=message.user_id%></h3>
                <p><b>date : </b><%=message.timestamp%></p>
                <p><b>text : </b> <%=message.text%></p>
            </li>
        <% }) %>
    </ul>
    <a href="/sign-up">Add a new user</a>
  </body>
</html>
